{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClipZen",
  "version": "0.1.0",
  "identifier": "com.lcb.clipzen",
  "plugins": {
    "dialog": null
  },
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ClipZen - 小安剪贴板",
        "width": 450,
        "height": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": true,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "小安剪贴板 - 快、稳、简单、隐私、离线",
    "longDescription": "ClipZen 是一款本地剪贴板管理工具，自动记录剪贴板历史，支持快速搜索、置顶常用内容，纯本地存储保护隐私。"
  }
}
